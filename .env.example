# Copy to .env and adjust if needed:  copy .env.example .env
# Used by Docker Compose and documented for Spring Boot (local profile reads POSTGRES_* via application.yml)

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=codele
POSTGRES_USER=codele
POSTGRES_PASSWORD=codele

SERVER_PORT=8080

# Admin account (created on first app startup if missing)
CODELE_ADMIN_USERNAME=admin
CODELE_ADMIN_EMAIL=admin@codele.local
CODELE_ADMIN_PASSWORD=Sader123@

